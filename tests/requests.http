### ======= Users ==========================================
### Get my profile
GET {{baseUrl}}/users/me
Authorization: Bearer {{token}}

### Update profile
PATCH {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "bio": "Hello I am a dev"
}

### Upload my avatar
POST {{baseUrl}}/users/me/avatar
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=----WebAppBoundary

------WebAppBoundary
Content-Disposition: form-data; name="file"; filename="avatar.jpg"
Content-Type: image/jpeg

< ./assets/avatar.jpg
------WebAppBoundary--

### ======= Rooms ==========================================
### Create a room
POST {{baseUrl}}/rooms
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "general",
  "description": "General chat",
  "is_private": false
}

### List all public rooms
GET {{ baseUrl }}/rooms
Authorization: Bearer {{token}}

### Get a specific room
GET {{ baseUrl }}/rooms/{{room}}
Authorization: Bearer {{token}}

### Update a room
PATCH {{ baseUrl }}/rooms/{{room}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Updated description"
}

### Join a room
POST {{ baseUrl }}/rooms/{{room}}/join
Authorization: Bearer {{token2}}

### List room members
GET {{ baseUrl }}/rooms/{{room}}/members
Authorization: Bearer {{token}}

### Leave a room
DELETE {{ baseUrl }}/rooms/{{room}}/leave
Authorization: Bearer {{token}}

### Kick a member (room admin only)
DELETE {{baseUrl}}/rooms/{{room}}/members/{{user2}}
Authorization: Bearer {{token}}

### Upload room avatar
POST {{baseUrl}}/rooms/{{room}}/avatar
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=----WebAppBoundary

------WebAppBoundary
Content-Disposition: form-data; name="file"; filename="room.jpg"
Content-Type: image/jpeg

< ./assets/banner.jpg
------WebAppBoundary--

### Who's online in this room
GET {{baseUrl}}/rooms/{{room}}/online
Authorization: Bearer {{token}}


### === Messages =======================================

### Send a message
# @name send_message
POST {{baseUrl}}/rooms/{{room}}/messages
Content-Type: application/json
Authorization: Bearer {{token2}}

{
  "content": "Hello, this is a test message"
}

### Get message history
GET {{baseUrl}}/rooms/{{room}}/messages
Authorization: Bearer {{token}}

### Get message history with limit
GET {{baseUrl}}/rooms/{{room}}/messages?limit=10
Authorization: Bearer {{token}}

### Get message history before a cursor
GET {{baseUrl}}/rooms/{{room}}/messages?before={{send_message.response.body.id}}
Authorization: Bearer {{token}}

### List room files
GET {{baseUrl}}/rooms/{{room}}/files
Authorization: Bearer {{token}}

### Upload file into room
POST {{baseUrl}}/rooms/{{room}}/files
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=----WebAppBoundary

------WebAppBoundary
Content-Disposition: form-data; name="file"; filename="room.jpg"
Content-Type: image/jpeg

< ./assets/message.jpg
------WebAppBoundary--

### Upload a file to a room
POST {{baseUrl}}/rooms/{{room}}/files
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=----WebAppBoundary

------WebAppBoundary
Content-Disposition: form-data; name="file"; filename="test.jpg"
Content-Type: image/jpeg

< ./assets/test.jpg
------WebAppBoundary--

### List room files
GET {{baseUrl}}/rooms/{{room}}/files
Authorization: Bearer {{token}}