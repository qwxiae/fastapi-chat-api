### ======= Users ==========================================
### Get my profile
GET {{baseUrl}}/users/me
Authorization: Bearer {{token}}

### Update profile
PATCH {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "bio": "Hello I am a dev"
}
### ======= Rooms ==========================================
### Create a room
POST {{baseUrl}}/rooms
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "general",
  "description": "General chat",
  "is_private": false
}

### List all public rooms
GET {{ baseUrl }}/rooms
Authorization: Bearer {{token}}

### Get a specific room
GET {{ baseUrl }}/rooms/{{room}}
Authorization: Bearer {{token}}

### Update a room
PATCH {{ baseUrl }}/rooms/{{room}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Updated description"
}

### Join a room
POST {{ baseUrl }}/rooms/{{room}}/join
Authorization: Bearer {{token2}}

### List room members
GET {{ baseUrl }}/rooms/{{room}}/members
Authorization: Bearer {{token2}}

### Leave a room
DELETE {{ baseUrl }}/rooms/{{room}}/leave
Authorization: Bearer {{token2}}

### Kick a member (room admin only)
DELETE {{baseUrl}}/rooms/{{room}}/members/{{user2}}
Authorization: Bearer {{token}}